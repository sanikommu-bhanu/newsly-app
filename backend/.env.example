# ─── Security ────────────────────────────────────────────────────────────────
# CHANGE THIS IN PRODUCTION — use: openssl rand -hex 32
SECRET_KEY=newsly-dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default). For Supabase replace with:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./newsly.db

# ─── Ollama (local LLM for article summaries) ────────────────────────────────
# Set OLLAMA_ENABLED=false to skip AI summaries (fallback to extractive)
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── News API (optional) ─────────────────────────────────────────────────────
NEWS_API_KEY=

# ─── News Cache ──────────────────────────────────────────────────────────────
# How long (seconds) to keep fetched articles in memory before re-fetching
NEWS_CACHE_TTL=900

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated frontend origins (no trailing slashes)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001,https://your-frontend.vercel.app
# Optional regex for Vercel preview deployments
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
